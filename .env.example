# --- App / runtime ---
ENVIRONMENT=local
LOG_LEVEL=INFO

# --- Auth (local dev fast-path) ---
# When true, a fake user/admin identity is injected; Keycloak not required.
DEV_AUTH=true
DEV_AUTH_ROLE=admin            # user | admin | auditor
DEV_AUTH_TENANT=dev-tenant
DEV_AUTH_EMAIL=dev@example.com

# --- LLM provider (pluggable) ---
LLM_PROVIDER=openai            # openai | anthropic | azure_openai
LLM_MODEL=gpt-4.1
LLM_API_KEY=sk-replace-me
# Azure OpenAI only:
# AZURE_OPENAI_ENDPOINT=https://your-aoai.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# --- Datastores ---
DATABASE_URL=postgresql+asyncpg://azsup:azsup@postgres:5432/azsup
REDIS_URL=redis://redis:6379/0

# --- Azure MCP server (spawned in-process via npx, stdio transport) ---
MCP_COMMAND=npx
MCP_ARGS=-y @azure/mcp@latest server start --transport stdio
# Read-only exposes only investigation tools (recommended). Gated-write execution
# is a later phase; the approval-gate infrastructure is already present.
MCP_READ_ONLY=true

# --- EntraID (Microsoft Graph) MCP server (vendored FastMCP server, stdio) ---
# Its heavy msgraph-sdk deps live in a dedicated venv (long-path safe). Point the
# command at that venv's python and the args at the stdio launcher. Authenticates
# to Graph with the default Azure connection's service-principal credentials.
ENTRA_MCP_COMMAND=C:\eidmcp\Scripts\python.exe
ENTRA_MCP_ARGS=./third_party/entraid-mcp-server/run_server.py
# Pin DefaultAzureCredential to the Azure CLI login (matches `az login`). On dev
# machines the default chain may resolve a broker/VS identity with no subscriptions.
AZURE_TOKEN_CREDENTIALS=AzureCliCredential
# Local Azure auth used by the MCP server (DefaultAzureCredential picks az login).
# For service principal instead, set these in addition to mounting nothing:
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# --- Agent safety ---
# gated = mutating tools require approval; read_only = never expose writes
AGENT_WRITE_POLICY=gated       # gated | read_only

# --- Secrets at rest (Azure connection credentials) ---
# Fernet key (urlsafe base64, 32 bytes) used to encrypt service-principal secrets and
# pasted tokens for multi-tenant Azure connections. Leave empty for local dev (a key is
# auto-generated at backend/.data/secret.key). In production, set a stable value from
# Key Vault. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_ENCRYPTION_KEY=

# --- CORS / frontend ---
FRONTEND_ORIGIN=http://localhost:5173
